# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=<your_bot_token>

# SQLite database path (required)
# Use ./data/wordlearn.db so host CLI can share DB with Docker bot.
WORDLEARN_DB_PATH=./data/wordlearn.db

# Optional: long-poll timeout in seconds (default: 30)
TELEGRAM_POLLING_TIMEOUT=30

# Optional: restrict bot access to specific Telegram user ids (comma-separated)
# Example: BOT_ALLOWED_USER_IDS=123456789,987654321
BOT_ALLOWED_USER_IDS=

# OpenAI API key for batch AI card generation (required for add-batch-ai flows)
OPENAI_API_KEY=

# Optional OpenAI-compatible settings
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt‑4o
OPENAI_TIMEOUT_SEC=30
OPENAI_MAX_RETRIES=2
# Prompt directory with per-language-pair files, e.g. prompt_en-pt.txt
OPENAI_PROMPTS_DIR=./prompts
